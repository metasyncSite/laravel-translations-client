{
    "name": "metasyncsite/laravel-translations-client",
    "description": "Laravel client package for pushing translations to the Translation Manager",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/http": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "TranslationsClient\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "TranslationsClient\\TranslationsClientServiceProvider"
            ]
        }
    },
    "version": "1.0.0",
    "minimum-stability": "stable",
    "prefer-stable": true
}
